# ReachStakes Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/reachstakes

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Tazapay (Payments & Payouts) ──────────────────────────────────────────────
# Sandbox: https://service-sandbox.tazapay.com
# Production: https://service.tazapay.com
TAZAPAY_API_BASE_URL=https://service-sandbox.tazapay.com
TAZAPAY_API_KEY=ak_test_your_key_here
TAZAPAY_API_SECRET=sk_test_your_secret_here
TAZAPAY_ACCOUNT_EMAIL=your-tazapay-account-email@example.com
TAZAPAY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── Encryption (REQUIRED for bank detail handling) ────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-generated-above

# ── Social Integrations ──────────────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ── General ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_EMAILS=admin@example.com
